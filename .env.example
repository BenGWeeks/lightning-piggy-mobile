# Maestro E2E test environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Nostr nsec key for login tests (primary identity)
MAESTRO_NSEC_BIG=nsec1...

# Second Nostr identity — used by tests that need two distinct actors,
# e.g. sending a DM from actor A and verifying receipt after switching
# the app to actor B. Generate a fresh key with:
#   node -e "const{generateSecretKey,getPublicKey,nip19}=require('nostr-tools');const sk=generateSecretKey();console.log(nip19.nsecEncode(sk),nip19.npubEncode(getPublicKey(sk)))"
MAESTRO_NSEC_LITTLE=nsec1...

# Three Piggy-named test wallets — paired NWC + on-chain so a single
# Piggy can act as both Lightning and on-chain payer/payee in the same
# flow. Used by tests added in PR #451 onwards. Big Piggy is the
# Boltz-swap-test designate (needs ≥25,000 sats per swap; keep more
# headroom in MAESTRO_NWC_BIG and at MAESTRO_ADDR_BIG than in the
# others). Lightning addresses must resolve to the same wallets as
# the corresponding NWC connection.

# Lightning (NWC) — must be quoted because of `&` in the URL.
MAESTRO_NWC_LITTLE="nostr+walletconnect://..."
MAESTRO_NWC_MIDDLE="nostr+walletconnect://..."
MAESTRO_NWC_BIG="nostr+walletconnect://..."

# Lightning addresses pointing at the same wallets as the NWC strings
# above (one per Piggy). Useful when a flow needs lud16 (e.g. zap to
# friend, pay-to-friend tests).
MAESTRO_LUD16_LITTLE=little.example@your-lnurl-host
MAESTRO_LUD16_MIDDLE=middle.example@your-lnurl-host
MAESTRO_LUD16_BIG=big.example@your-lnurl-host

# On-chain (BIP-84 native segwit, derivation m/84'/0'/0', addresses
# bc1q…). The MAESTRO_ADDR_* shorthand is the first receive address
# derived from the corresponding xpub — convenient for Maestro flows
# that paste an address without re-deriving from the xpub at runtime.
# Generate a fresh wallet with bip39 + bip32 (e.g. via the npm
# packages of those names) — never commit a real seed.
MAESTRO_MNEMONIC_LITTLE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
MAESTRO_XPUB_LITTLE=xpub6...
MAESTRO_ADDR_LITTLE=bc1q...
MAESTRO_MNEMONIC_MIDDLE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
MAESTRO_XPUB_MIDDLE=xpub6...
MAESTRO_ADDR_MIDDLE=bc1q...
MAESTRO_MNEMONIC_BIG="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
MAESTRO_XPUB_BIG=xpub6...
MAESTRO_ADDR_BIG=bc1q...

# Legacy on-chain test fixtures (kept for backward-compat with older
# flows; new tests should prefer the Piggy-named wallets above).
MAESTRO_XPUB1=xpub6...
MAESTRO_MNEMONIC1="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
MAESTRO_XPUB2=xpub6...
MAESTRO_MNEMONIC2="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
# Watch-only on-chain wallet (xpub only, no mnemonic) used by the add-onchain E2E test
MAESTRO_XPUB3=xpub6...

# --- Wallet-seeder subflow inputs (issue #291) ---------------------------
# Test fixtures only — leave blank if you're not running wallet-conditional
# Maestro tests that depend on `_subflow-seed-test-wallet.yaml`. Set EXACTLY
# ONE of these per invocation; the subflow picks the wallet type based on
# which one is non-empty.
#
# MAESTRO_TEST_NWC      — NWC connection string for Lightning seeding
#                          (typically the same value as MAESTRO_NWC_LITTLE
#                          or another Piggy NWC depending on which actor
#                          the calling flow is acting as)
# MAESTRO_TEST_MNEMONIC — 12/24-word seed phrase for an on-chain hot wallet
#                          (requires dev mode enabled in the app). MUST be
#                          quoted because it contains spaces — same shape
#                          as MAESTRO_MNEMONIC_LITTLE/MIDDLE/BIG above.
MAESTRO_TEST_NWC=""
MAESTRO_TEST_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
