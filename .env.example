# Maestro E2E test environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Nostr nsec key for login tests (primary identity)
MAESTRO_NSEC=nsec1...

# Second Nostr identity — used by tests that need two distinct actors,
# e.g. sending a DM from actor A and verifying receipt after switching
# the app to actor B. Generate a fresh key with:
#   node -e "const{generateSecretKey,getPublicKey,nip19}=require('nostr-tools');const sk=generateSecretKey();console.log(nip19.nsecEncode(sk),nip19.npubEncode(getPublicKey(sk)))"
MAESTRO_NSEC2=nsec1...

# On-chain wallet 1 (for future hot-wallet send tests)
MAESTRO_XPUB1=xpub6...
MAESTRO_MNEMONIC1="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# On-chain wallet 2
MAESTRO_XPUB2=xpub6...
MAESTRO_MNEMONIC2="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Watch-only on-chain wallet (xpub only, no mnemonic) used by the add-onchain E2E test
MAESTRO_XPUB3=xpub6...

# NWC connection strings for Lightning wallet tests (must be quoted due to & in URL)
MAESTRO_NWC1="nostr+walletconnect://..."
MAESTRO_NWC2="nostr+walletconnect://..."
