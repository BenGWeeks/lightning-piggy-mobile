# Maestro E2E test environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Nostr nsec key for login tests
MAESTRO_NSEC=nsec1...

# On-chain wallet xpub for import tests (BIP-84 derivation)
MAESTRO_XPUB=xpub6...
# BIP-84 mnemonic for the xpub above (for future hot-wallet send tests)
MAESTRO_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
# Optional: zpub with existing transactions for testing transaction display
MAESTRO_XPUB_TEST=zpub6...

# NWC connection strings for Lightning wallet tests
MAESTRO_NWC1=nostr+walletconnect://...
MAESTRO_NWC2=nostr+walletconnect://...
