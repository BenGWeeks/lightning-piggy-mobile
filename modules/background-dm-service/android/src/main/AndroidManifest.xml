<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!--
    The foreground Service + boot receiver are declared HERE, in the local
    Expo module, rather than injected into the app manifest by the config
    plugin. The classes they name live in this same module, so they compile
    together and the manifest can never point at a missing class (the exact
    prebuild-breaking hazard that kept plugins/withForegroundService.js from
    adding a <service> on its own). The module manifest is merged into the
    app manifest at build time.

    Permissions (FOREGROUND_SERVICE, FOREGROUND_SERVICE_DATA_SYNC,
    POST_NOTIFICATIONS, RECEIVE_BOOT_COMPLETED, WAKE_LOCK) stay declared in
    the app manifest via plugins/withForegroundService.js — they're meaningful
    on their own and surface in the install prompt.
  -->

  <application>
    <!--
      foregroundServiceType="dataSync": we're keeping a relay WebSocket alive
      to sync inbound DMs. Android 14 (API 34)+ requires both the type here
      AND the FOREGROUND_SERVICE_DATA_SYNC permission.
      exported="false": only our own app may start it.
      stopWithTask="false": survive the user swiping the app from Recents, so
      the watch keeps running like Amethyst's.
    -->
    <service
      android:name="com.lightningpiggy.backgrounddm.BackgroundDmService"
      android:enabled="true"
      android:exported="false"
      android:foregroundServiceType="dataSync"
      android:stopWithTask="false" />

    <!--
      Re-arm the watch after a device reboot. Uses RECEIVE_BOOT_COMPLETED
      (declared in the app manifest). The receiver only relaunches the
      service; the headless JS task it hosts self-checks the persisted
      enable/disable preference and stops itself immediately if the user has
      the feature turned off, so a reboot never resurrects a disabled watch.
    -->
    <receiver
      android:name="com.lightningpiggy.backgrounddm.BootReceiver"
      android:enabled="true"
      android:exported="false">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
