<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!--
    The foreground Service + boot receiver are declared HERE, in the local
    Expo module, rather than injected into the app manifest by the config
    plugin. The classes they name live in this same module, so they compile
    together and the manifest can never point at a missing class (the exact
    prebuild-breaking hazard that kept plugins/withForegroundService.js from
    adding a <service> on its own). The module manifest is merged into the
    app manifest at build time.

    Permissions (FOREGROUND_SERVICE, FOREGROUND_SERVICE_SPECIAL_USE,
    POST_NOTIFICATIONS, RECEIVE_BOOT_COMPLETED) stay declared in the app
    manifest via plugins/withForegroundService.js — they're meaningful on
    their own and surface in the install prompt.
  -->

  <application>
    <!--
      foregroundServiceType="specialUse" (was dataSync): Android 15 caps
      dataSync services at 6h per 24h and forbids starting them from
      BOOT_COMPLETED; specialUse has neither restriction. Requires the
      FOREGROUND_SERVICE_SPECIAL_USE permission (app manifest, via
      plugins/withForegroundService.js) plus the FGS_SUBTYPE property below
      declaring the concrete use for platform/store review.
      exported="false": only our own app may start it.
      stopWithTask="false": survive the user swiping the app from Recents, so
      the watch keeps running like Amethyst's.
    -->
    <service
      android:name="com.lightningpiggy.backgrounddm.BackgroundDmService"
      android:enabled="true"
      android:exported="false"
      android:foregroundServiceType="specialUse"
      android:stopWithTask="false">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Opt-in realtime direct-message notifications over a user-configured Nostr relay WebSocket, without FCM/push services (the app targets de-googled devices). Runs only while the in-app toggle is enabled; a persistent status notification is always shown." />
    </service>

    <!--
      Re-arm the watch after a device reboot. Uses RECEIVE_BOOT_COMPLETED
      (declared in the app manifest). The receiver only relaunches the
      service; the headless JS task it hosts self-checks the persisted
      enable/disable preference and stops itself immediately if the user has
      the feature turned off, so a reboot never resurrects a disabled watch.
    -->
    <receiver
      android:name="com.lightningpiggy.backgrounddm.BootReceiver"
      android:enabled="true"
      android:exported="false">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
